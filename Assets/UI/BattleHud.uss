.root {
    -unity-font-style: bold;
    color: rgb(230, 230, 230);
    padding: 12px;
}

.count {
    font-size: 22px;
    margin-bottom: 4px;
}

.count-red  { color: rgb(255, 90, 90); }
.count-blue { color: rgb(110, 170, 255); }

.winner {
    font-size: 48px;
    -unity-text-align: middle-center;
    color: rgb(255, 220, 60);
    margin-top: 32px;
}
