# Unity .gitattributes
# Normalize all text files to LF in the repo; let git convert on checkout.

* text=auto

# Unity YAML (force text, LF)
*.cs        text eol=lf
*.shader    text eol=lf
*.cginc     text eol=lf
*.hlsl      text eol=lf
*.asmdef    text eol=lf
*.asmref    text eol=lf
*.json      text eol=lf
*.xml       text eol=lf
*.txt       text eol=lf
*.md        text eol=lf

# Unity serialized files — store as LF (Unity writes LF on all platforms)
*.unity     text eol=lf
*.prefab    text eol=lf
*.asset     text eol=lf
*.meta      text eol=lf
*.mat       text eol=lf
*.anim      text eol=lf
*.controller text eol=lf
*.overrideController text eol=lf
*.mask      text eol=lf
*.lighting  text eol=lf
*.playable  text eol=lf
*.signal    text eol=lf

# Binary files — never touch line endings
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.bmp       binary
*.tga       binary
*.tif       binary
*.tiff      binary
*.psd       binary
*.pdf       binary
*.zip       binary
*.7z        binary
*.gz        binary
*.tar       binary
*.dll       binary
*.so        binary
*.dylib     binary
*.exe       binary
*.fbx       binary
*.obj       binary
*.wav       binary
*.ogg       binary
*.mp3       binary
*.mp4       binary
*.mov       binary
*.ttf       binary
*.otf       binary
*.cubemap   binary
*.unitypackage binary
